   }
 
+  // jc-overlay: ephemeral attachments — keep media only for the current turn
+  // (messages at/after the last user message); strip from older history so
+  // large base64 PDFs/images are not resent every request.
+  let __lastUserIdx = -1
+  for (let __i = input.length - 1; __i >= 0; __i--) {
+    if (input[__i].info.role === "user") {
+      __lastUserIdx = __i
+      break
+    }
+  }
+  let __msgIdx = -1
   for (const msg of input) {
+    __msgIdx++
     if (msg.parts.length === 0) continue
 
     if (msg.info.role === "user") {
@@ -791,7 +803,11 @@
